# Server Environment Variables

MONGODB_URI=<YOUR_MONGODB_CONNECTION_STRING>
JWT_SECRET=<JWT_SECRET>
PORT=5001
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173

# SendGrid API Key (replaces Nodemailer/Gmail — Render blocks SMTP ports on free tier)
# 1. Sign up at https://sendgrid.com (free tier: 100 emails/day)
# 2. Create an API key at https://app.sendgrid.com/settings/api_keys
# 3. Verify a Single Sender at https://app.sendgrid.com/settings/sender_auth/senders
#    (Use noreply.exchangebook@gmail.com or any email you own)
SENDGRID_API_KEY=SG.your-api-key-here
SENDGRID_FROM_EMAIL=noreply.exchangebook@gmail.com

# Frontend URL (used in email verification and password reset links)
FRONTEND_URL=http://localhost:5173

# DEPRECATED — kept for reference (SMTP blocked on Render free tier)
# GMAIL_USER=your.email@gmail.com
# GMAIL_APP_PASSWORD=your-16-digit-app-password
